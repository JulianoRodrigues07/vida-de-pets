generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Agendamento {
  id        Int      @id @default(autoincrement())
  nome      String
  telefone  String
  servico   String
  data      String
  horario   String
  status    String   @default("pendente")
  criadoEm  DateTime @default(now())
}